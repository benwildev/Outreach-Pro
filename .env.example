# Neon PostgreSQL connection string
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# SMTP (optional, for provider = smtp)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# App URL for tracking pixel and click redirects (e.g. https://yourapp.vercel.app)
NEXT_PUBLIC_APP_URL=

# Vercel Cron: set in Vercel dashboard; cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Gmail API (for reply detection at /api/automation/replies)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# IP allowlist (optional): comma-separated list of allowed client IPs.
# If unset or empty, all IPs are allowed (open access).
# Example: ALLOWED_IPS=1.2.3.4,5.6.7.8
ALLOWED_IPS=
