generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campaign {
  id            String      @id @default(cuid())
  name          String
  subject       String
  body          String
  chatGptChatId String?
  gmailAuthUser String?
  followup1          String?
  followup2          String?
  followup1Templates String?
  signature     String?
  delay1Days    Int         @default(3)
  delay2Days    Int         @default(5)
  provider      String      @default("gmail")
  createdAt     DateTime    @default(now())
  webhookUrl         String?
  googleSheetId      String?
  gmailAccountIndex  Int?
  importLogs    ImportLog[]
  leads         Lead[]

  @@map("campaign")
}

model ImportLog {
  id            String   @id @default(cuid())
  campaignId    String
  fileName      String
  startRow      Int
  endRow        Int
  importedCount Int
  skippedCount  Int
  createdAt     DateTime @default(now())
  campaign      Campaign @relation(fields: [campaignId], references: [id])

  @@map("import_log")
}

model AllowedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  label     String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("allowed_ip")
}

model AppSetting {
  key   String @id
  value String

  @@map("app_setting")
}

model GmailAccountMap {
  id           String   @id @default(cuid())
  email        String   @unique
  accountIndex Int
  source       String?  @default("auto")
  updatedAt    DateTime @updatedAt

  @@map("gmail_account_map")
}

model Lead {
  id                 String    @id @default(cuid())
  campaignId         String
  recipientName      String
  recipientEmail     String
  websiteUrl         String?
  niche              String?
  status             String    @default("pending")
  step               Int       @default(1)
  replied            Boolean   @default(false)
  sentAt             DateTime?
  sentGmailAuthUser  String?
  sentSubject        String?
  sentBody           String?
  nextFollowup       DateTime?
  gmailThreadId      String?
  opened             Boolean   @default(false)
  openedAt           DateTime?
  clicked            Boolean   @default(false)
  clickedAt          DateTime?
  createdAt          DateTime  @default(now())
  replyBody          String?
  sentFollowup1Body  String?
  sentFollowup2Body  String?
  lastReplyCheckedAt DateTime?
  replyCategory      String?
  unsubscribed       Boolean   @default(false)
  bouncedEmail       String?
  claimedAt          DateTime?
  campaign           Campaign  @relation(fields: [campaignId], references: [id])

  @@map("lead")
}
